{
  "name": "bun-plugin-relay",
  "version": "0.1.0",
  "description": "Bun build plugin that replaces graphql tagged template literals with require() calls to relay-compiler generated artifacts",
  "module": "src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "LICENSE"
  ],
  "keywords": [
    "bun",
    "relay",
    "graphql",
    "plugin",
    "bundler"
  ],
  "scripts": {
    "format": "biome check --fix",
    "check:lint": "biome check",
    "check:types": "tsc --noEmit"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/barodeur/bun-plugin-relay.git"
  },
  "homepage": "https://github.com/barodeur/bun-plugin-relay",
  "bugs": {
    "url": "https://github.com/barodeur/bun-plugin-relay/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tsconfig/bun": "^1.0.10",
    "@tsconfig/strictest": "^2.0.8",
    "@types/bun": "^1.3.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
